{
  "manifest_version": 3,
  "name": "GeoLens",
  "version": "0.1.3",
  "description": "Interactive GeoGuessr stats overlay with country-level tracking and world map visualization.",
  "host_permissions": ["https://www.geoguessr.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.geoguessr.com/*"],
      "js": ["build/content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["build/assets/admin0_mapunits_simplified.geojson", "build/assets/geolens.png"],
      "matches": ["https://www.geoguessr.com/*"]
    }
  ],
  "icons": {
    "128": "build/assets/geolens.png"
  }
}
